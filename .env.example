# GalleryPack — environment variables
# Copy this file to .env and fill in the required values.
# Generate secrets with: openssl rand -hex 32

# ── Required ───────────────────────────────────────────────────────────────────

# Admin account password (bootstrapped on first start if no users exist)
ADMIN_PASSWORD=change-me

# Signs admin session cookies
SESSION_SECRET=change-me

# Signs gallery viewer tokens
VIEWER_TOKEN_SECRET=change-me

# ── Database ───────────────────────────────────────────────────────────────────

DB_NAME=gallerypack
DB_USER=gallerypack
DB_PASS=change-me
DB_ROOT_PASSWORD=change-me

# ── Network / Domain ───────────────────────────────────────────────────────────

# Your public domain — Caddy provisions TLS automatically via Let's Encrypt
DOMAIN=localhost

# Full public URL (used in invite emails and gallery links)
BASE_URL=http://localhost

# Platform mode: "single" (one studio) or "saas" (multi-tenant subdomains)
PLATFORM_MODE=single

# Root domain for multi-tenant subdomain routing (saas mode only)
# BASE_DOMAIN=gallerypack.app

# ── Storage ────────────────────────────────────────────────────────────────────

# local (default) or s3
STORAGE_DRIVER=local

# Root path for local storage (inside the container)
# Maps to /srv/gallerypack inside the container; mounted from ./data on the host
STORAGE_ROOT=/srv/gallerypack

# S3 / R2 / MinIO — only needed when STORAGE_DRIVER=s3
# S3_BUCKET=gallerypack
# S3_REGION=auto
# S3_ENDPOINT=https://your-account.r2.cloudflarestorage.com
# S3_ACCESS_KEY_ID=
# S3_SECRET_ACCESS_KEY=

# ── Email ──────────────────────────────────────────────────────────────────────

# null = log to console (dev), smtp = send via SMTP
EMAIL_PROVIDER=null

# SMTP settings — only needed when EMAIL_PROVIDER=smtp
# SMTP_HOST=smtp.example.com
# SMTP_PORT=587
# SMTP_SECURE=false        # true for port 465
# SMTP_USER=you@example.com
# SMTP_PASS=your-app-password
# SMTP_FROM=GalleryPack <noreply@photos.example.com>
